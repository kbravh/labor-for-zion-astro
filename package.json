{
	"name": "labor-for-zion-astro",
	"type": "module",
	"version": "1.0.0",
	"license": "MIT",
	"engines": {
		"node": "24"
	},
	"scripts": {
		"dev": "astro dev",
		"start": "node ./dist/server/entry.mjs",
		"build": "astro build --remote",
		"preview": "astro preview",
		"astro": "astro",
		"format": "prettier --write .",
		"lint": "eslint --fix .",
		"check": "npm run format && npm run lint",
		"test": "vitest",
		"test:visual": "vitest --ui --coverage",
		"test:coverage": "vitest run --coverage",
		"upgrade": "npx npm-check-updates -i --format group",
		"upgrade:astro": "npx @astrojs/upgrade",
		"video:transcode": "tsx node ./scripts/transcode.ts",
		"video:upload": "tsx node ./scripts/upload.ts",
		"db:push": "npm run astro db push -- --remote"
	},
	"dependencies": {
		"@astrojs/db": "^0.21.3",
		"@astrojs/node": "^11.0.0",
		"@astrojs/rss": "^4.0.19",
		"@astrojs/sitemap": "^3.7.3",
		"@tailwindcss/vite": "^4.3.0",
		"astro": "^7.0.4",
		"dotenv": "^17.4.2",
		"eslint-plugin-astro": "^1.7.0",
		"fluent-ffmpeg": "^2.1.3",
		"gray-matter": "^4.0.3",
		"hls-video-element": "^1.5.11",
		"linkedom": "^0.18.12",
		"markdown-it": "^14.2.0",
		"markdown-it-anchor": "^9.2.0",
		"markdown-it-footnote": "^4.0.0",
		"media-chrome": "^4.19.0",
		"nanoid": "^5.1.11",
		"sanitize-html": "^2.17.4",
		"slugify": "^1.6.9",
		"tailwindcss": "^4.3.0",
		"vitest": "^4.1.7",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@tailwindcss/typography": "^0.5.19",
		"@types/aws-lambda": "^8.10.161",
		"@types/fluent-ffmpeg": "^2.1.28",
		"@types/markdown-it": "^14.1.2",
		"@types/markdown-it-footnote": "^3.0.4",
		"@types/node": "^24.10.4",
		"@types/sanitize-html": "^2.16.1",
		"@vitest/coverage-v8": "^4.1.7",
		"@vitest/ui": "^4.1.7",
		"esbuild": "^0.28.1",
		"eslint": "^10.4.0",
		"jsdom": "^29.1.1",
		"memfs": "^4.57.2",
		"prettier": "^3.8.3",
		"prettier-plugin-astro": "^0.14.1",
		"tsx": "^4.22.3",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.60.0",
		"wrangler": "^4.95.0"
	}
}
